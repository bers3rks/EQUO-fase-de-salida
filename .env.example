# ─────────────────────────────────────────────────────────────────────────────
# EQUO — Variables de entorno para Vercel
# Configura estas variables en Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Binance Pay ───────────────────────────────────────────────────────────────
# Obtenlas en: https://merchant.binance.com → Configuración de pago
BINANCE_API_KEY=tu-api-key-de-binance-pay
BINANCE_SECRET_KEY=tu-secret-key-de-binance-pay

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Obtenlas en: Firebase Console → Configuración del proyecto → Cuentas de servicio
# → Generar nueva clave privada
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com

# IMPORTANTE: En Vercel, copia el valor de private_key del JSON tal cual.
# Vercel maneja los saltos de línea automáticamente.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
